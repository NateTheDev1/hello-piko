{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@nrichardsdev/piko-sdk":        ["../../piko-sdk/src/index.ts"],
      "@nrichardsdev/piko-sdk/react":  ["../../piko-sdk/src/react.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
